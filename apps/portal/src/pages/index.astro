---
import Base from '../layouts/Base.astro';
import projects from '../data/projects.json';
import highlights from '../data/highlights.json';
import type { Project, Highlight } from '../lib/types';

const projectList = projects as Project[];
const highlightList = highlights as Highlight[];

// 每个项目的亮点（按 sort_order，前 3 条）；优先挑有 metric 的。
const topHighlights = (pid: string): Highlight[] =>
  highlightList
    .filter((h) => h.project_id === pid)
    .sort((a, b) => a.sort_order - b.sort_order)
    .slice(0, 3);
---

<Base title="作品门户 · 首页" path="/">
  <section class="mb-12">
    <h1 class="text-4xl font-bold tracking-tight">我做的产品</h1>
    <p class="mt-3 text-muted-foreground">
      小程序与全栈应用 · 介绍 / 技术亮点 / 版本更新
    </p>
  </section>

  {
    projectList.length === 0 ? (
      <p class="rounded-lg border border-dashed bg-muted/20 p-12 text-center text-sm text-muted-foreground">
        尚未发布任何作品。请到后台 CMS 录入并发布。
      </p>
    ) : (
      <div class="grid gap-6 md:grid-cols-2">
        {projectList.map((p) => {
          const hs = topHighlights(p.id);
          const stack = (p.tech_stack ?? []).slice(0, 6);
          return (
            <a
              href={`/projects/${p.slug}`}
              class="group flex flex-col overflow-hidden rounded-lg border transition-shadow hover:shadow-md"
            >
              <div class="flex aspect-[3/1] items-center justify-center bg-gradient-to-br from-muted to-muted/40 text-muted-foreground">
                {p.cover_url ? (
                  <img
                    src={p.cover_url}
                    alt={p.display_name}
                    class="h-full w-full object-cover"
                    loading="lazy"
                  />
                ) : (
                  <span class="text-sm">封面占位 · {p.display_name}</span>
                )}
              </div>
              <div class="flex flex-1 flex-col p-6">
                <div class="flex items-baseline justify-between gap-4">
                  <h2 class="text-xl font-semibold group-hover:text-primary">
                    {p.display_name}
                  </h2>
                  {p.current_version && (
                    <span class="shrink-0 rounded-full border px-2 py-0.5 text-xs font-medium text-muted-foreground">
                      v{p.current_version}
                    </span>
                  )}
                </div>
                {p.tagline && (
                  <p class="mt-2 line-clamp-2 text-sm text-muted-foreground">{p.tagline}</p>
                )}
                {stack.length > 0 && (
                  <div class="mt-3 flex flex-wrap gap-1.5">
                    {stack.map((t) => (
                      <span class="rounded bg-muted px-1.5 py-0.5 text-[11px] text-muted-foreground">
                        {t}
                      </span>
                    ))}
                  </div>
                )}
                {hs.length > 0 && (
                  <ul class="mt-4 space-y-1.5">
                    {hs.map((h) => (
                      <li class="flex items-center justify-between gap-2 text-sm">
                        <span class="truncate text-foreground/80">{h.title}</span>
                        {h.metric_value && (
                          <span class="shrink-0 rounded bg-primary/10 px-1.5 py-0.5 text-xs font-semibold text-primary">
                            {h.metric_label && <span class="mr-1 opacity-70">{h.metric_label}</span>}
                            {h.metric_value}
                          </span>
                        )}
                      </li>
                    ))}
                  </ul>
                )}
                <span class="mt-auto pt-4 text-xs font-medium text-primary opacity-0 transition-opacity group-hover:opacity-100">
                  查看详情 →
                </span>
              </div>
            </a>
          );
        })}
      </div>
    )
  }
</Base>
