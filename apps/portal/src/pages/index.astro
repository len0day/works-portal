---
import Base from '../layouts/Base.astro';
import projectsData from '../data/projects.json';
import highlightsData from '../data/highlights.json';
import type { Project, Highlight } from '../lib/types';

const projectList = projectsData as Project[];
const highlightList = highlightsData as Highlight[];

const topHighlights = (pid: string): Highlight[] =>
  highlightList
    .filter((h) => h.project_id === pid)
    .sort((a, b) => a.sort_order - b.sort_order)
    .slice(0, 3);

const FORM_LABELS: Record<string, string> = {
  wechat_mp: '微信小程序',
  fullstack: '全栈应用',
  website: 'Web 应用',
  other: '其他',
};
---

<Base title="作品门户 · 首页" path="/">
  <!-- Hero -->
  <section class="mb-16">
    <div class="flex items-center gap-4 mb-6">
      <div class="flex items-baseline gap-2">
        <span class="font-mono italic text-neutral-500 text-sm">01</span>
        <span class="text-xs font-mono uppercase tracking-[0.3em] text-neutral-600">精选作品</span>
      </div>
      <div class="h-px flex-1 bg-gradient-to-r from-white/10 to-transparent"></div>
    </div>
    <h1 class="text-5xl md:text-7xl font-bold tracking-tighter leading-[0.9] mb-4">
      我做的 <span class="text-neutral-500 italic font-serif">产品</span>
    </h1>
    <p class="text-neutral-500 text-lg">小程序与全栈应用 &middot; 技术亮点 / 版本更新</p>
  </section>

  {
    projectList.length === 0 ? (
      <p class="rounded-lg border border-dashed border-white/10 bg-white/[0.02] p-12 text-center text-sm text-neutral-600">
        尚未发布任何作品。请到后台 CMS 录入并发布。
      </p>
    ) : (
      <div class="grid gap-6 md:grid-cols-2">
        {projectList.map((p, i) => {
          const hs = topHighlights(p.id);
          const stack = (p.tech_stack ?? []).slice(0, 5);
          const formLabel = FORM_LABELS[p.form ?? ''] ?? p.form;
          return (
            <a
              href={`/projects/${p.slug}`}
              class={`group relative flex flex-col overflow-hidden rounded-xl border border-white/5 bg-neutral-900/40 transition-all duration-300 hover:border-white/15 hover:bg-neutral-900/80 hover:shadow-xl hover:shadow-black/40 ${
                i === 0 ? 'md:col-span-2' : ''
              }`}
            >
              <!-- Cover -->
              <div class={`overflow-hidden bg-neutral-900 ${
                i === 0 ? 'aspect-[21/7]' : 'aspect-[4/3]'
              }`}>
                {p.cover_url ? (
                  <img
                    src={p.cover_url}
                    alt={p.display_name}
                    class="h-full w-full object-cover transition-transform duration-700 group-hover:scale-105"
                    loading={i === 0 ? 'eager' : 'lazy'}
                  />
                ) : (
                  <div class="flex h-full items-center justify-center">
                    <span class="font-mono text-sm text-neutral-700">{p.code}</span>
                  </div>
                )}
                <!-- Gradient overlay -->
                <div class="absolute inset-0 bg-gradient-to-t from-neutral-950/80 via-transparent to-transparent"></div>
              </div>

              <!-- Content -->
              <div class="relative flex flex-1 flex-col p-6">
                <div class="flex items-start justify-between gap-4 mb-3">
                  <div>
                    {formLabel && (
                      <span class="text-[10px] font-mono text-neutral-600 uppercase tracking-widest block mb-1">
                        {formLabel}
                      </span>
                    )}
                    <h2 class="text-xl font-semibold tracking-tight group-hover:text-white transition-colors">
                      {p.display_name}
                    </h2>
                  </div>
                  <div class="flex items-center gap-2 shrink-0 mt-1">
                    {p.current_version && (
                      <span class="rounded-full border border-white/10 bg-white/5 px-2.5 py-0.5 text-xs font-mono text-neutral-400">
                        v{p.current_version}
                      </span>
                    )}
                  </div>
                </div>

                {p.tagline && (
                  <p class="mb-4 text-sm text-neutral-400 leading-relaxed line-clamp-2">{p.tagline}</p>
                )}

                {stack.length > 0 && (
                  <div class="mb-4 flex flex-wrap gap-1.5">
                    {stack.map((t) => (
                      <span class="rounded bg-white/5 px-2 py-0.5 text-[11px] font-mono text-neutral-500 border border-white/5">
                        {t}
                      </span>
                    ))}
                  </div>
                )}

                {hs.length > 0 && (
                  <div class="mt-auto pt-4 border-t border-white/5 grid grid-cols-3 gap-3">
                    {hs.map((h) => (
                      <div>
                        <div class="text-lg font-bold font-mono text-white leading-none">
                          {h.metric_value ?? '—'}
                        </div>
                        {h.metric_label && (
                          <div class="text-[10px] text-neutral-600 mt-0.5">{h.metric_label}</div>
                        )}
                        <div class="text-xs text-neutral-500 mt-0.5 truncate">{h.title}</div>
                      </div>
                    ))}
                  </div>
                )}

                <span class="mt-4 text-xs font-mono text-neutral-600 opacity-0 transition-all duration-200 group-hover:opacity-100 group-hover:text-white">
                  查看详情 →
                </span>
              </div>
            </a>
          );
        })}
      </div>
    )
  }
</Base>
