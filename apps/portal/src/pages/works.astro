---
import Base from '../layouts/Base.astro';
import projectsData from '../data/projects.json';
import highlightsData from '../data/highlights.json';
import type { Project, Highlight } from '../lib/types';

const allProjects   = projectsData  as Project[];
const highlightList = highlightsData as Highlight[];

const topHighlights = (pid: string): Highlight[] =>
  highlightList
    .filter((h) => h.project_id === pid)
    .sort((a, b) => a.sort_order - b.sort_order)
    .slice(0, 3);

const FORM_LABELS: Record<string, string> = {
  wechat_mp: '微信小程序',
  fullstack:  '全栈应用',
  website:    'Web 应用',
  other:      '其他',
};

// 统计各分类数量（用于过滤按钮徽章）
const formCounts: Record<string, number> = {};
allProjects.forEach((p) => {
  const key = p.form ?? 'other';
  formCounts[key] = (formCounts[key] ?? 0) + 1;
});

const FILTERS = [
  { key: 'all',       label: '全部',      count: allProjects.length },
  { key: 'wechat_mp', label: '微信小程序', count: formCounts['wechat_mp'] ?? 0 },
  { key: 'fullstack', label: '全栈应用',   count: formCounts['fullstack'] ?? 0 },
  { key: 'website',   label: 'Web 应用',  count: formCounts['website'] ?? 0 },
  { key: 'other',     label: '其他',      count: formCounts['other'] ?? 0 },
].filter((f) => f.key === 'all' || f.count > 0);
---

<Base title="全部作品 · 作品门户" path="/works">

  <!-- Header -->
  <section class="header-section">
    <div class="label-row">
      <span class="font-mono italic text-neutral-600 text-sm">02</span>
      <span class="text-xs font-mono uppercase tracking-[0.3em] text-neutral-700">全部作品</span>
      <div class="h-px flex-1 bg-gradient-to-r from-white/10 to-transparent"></div>
    </div>
    <h1 class="works-title">项目<br /><em class="not-italic text-neutral-500" style="font-family: Georgia, serif;">全览</em></h1>
    <p class="text-neutral-500 mt-4">共 {allProjects.length} 个已发布项目</p>
  </section>

  <!-- Filter buttons -->
  <div class="filter-bar" id="filter-bar">
    {FILTERS.map(({ key, label, count }) => (
      <button
        class={`filter-btn ${ key === 'all' ? 'active' : '' }`}
        data-filter={key}
      >
        {label}
        <span class="filter-count">{count}</span>
      </button>
    ))}
  </div>

  <!-- Projects grid -->
  <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-3 mt-8" id="projects-grid">
    {allProjects.map((p) => {
      const hs    = topHighlights(p.id);
      const stack = (p.tech_stack ?? []).slice(0, 4);
      const formLabel = FORM_LABELS[p.form ?? ''] ?? p.form;
      return (
        <a
          href={`/projects/${p.slug}`}
          class="work-card group"
          data-form={p.form ?? 'other'}
        >
          <!-- Cover -->
          <div class="work-cover aspect-[4/3]">
            {p.cover_url && (
              <img
                src={p.cover_url}
                alt={p.display_name}
                class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                loading="lazy"
              />
            )}
            {!p.cover_url && (
              <div class="flex h-full items-center justify-center">
                <span class="font-mono text-sm text-neutral-700">{p.code}</span>
              </div>
            )}
            <div class="work-overlay"></div>
            {formLabel && (
              <span class="work-badge">{formLabel}</span>
            )}
          </div>

          <!-- Info -->
          <div class="work-info">
            <div class="flex items-start justify-between gap-2 mb-2">
              <h2 class="font-semibold text-base tracking-tight leading-snug">{p.display_name}</h2>
              {p.current_version && (
                <span class="text-[10px] font-mono text-neutral-600 shrink-0 mt-0.5 pt-0.5">v{p.current_version}</span>
              )}
            </div>

            {p.tagline && (
              <p class="text-xs text-neutral-500 leading-relaxed line-clamp-2 mb-3">{p.tagline}</p>
            )}

            {stack.length > 0 && (
              <div class="flex flex-wrap gap-1">
                {stack.map((t) => (
                  <span class="text-[10px] font-mono bg-white/4 border border-white/5 px-1.5 py-0.5 rounded text-neutral-600">{t}</span>
                ))}
              </div>
            )}

            {hs.length > 0 && (
              <div class="mt-3 pt-3 border-t border-white/5 flex gap-4">
                {hs.slice(0, 2).map((h) => (
                  <div>
                    <div class="text-sm font-bold font-mono text-white">{h.metric_value ?? '—'}</div>
                    <div class="text-[10px] text-neutral-600 truncate max-w-[80px]">{h.title}</div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </a>
      );
    })}
  </div>

  <!-- Empty state (shown by JS when filter returns nothing) -->
  <p id="empty-state" class="hidden mt-12 text-center text-sm text-neutral-600 py-12 border border-dashed border-white/8 rounded-xl">
    该分类暂无项目
  </p>

</Base>

<style>
  @keyframes fade-up {
    from { opacity: 0; transform: translateY(16px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .header-section { animation: fade-up 0.6s ease both; }
  .works-title {
    font-size: clamp(3rem, 9vw, 5.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 0.9;
    margin-top: 2rem;
  }
  .label-row { display: flex; align-items: center; gap: 1rem; }

  /* Filter bar */
  .filter-bar {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255,255,255,0.05);
  }
  .filter-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.375rem 0.875rem;
    border-radius: 9999px;
    border: 1px solid rgba(255,255,255,0.08);
    background: transparent;
    color: #737373;
    font-size: 0.8rem;
    font-family: monospace;
    cursor: pointer;
    transition: all 0.15s;
  }
  .filter-btn:hover { border-color: rgba(255,255,255,0.2); color: #fff; }
  .filter-btn.active {
    background: #fff;
    color: #000;
    border-color: #fff;
  }
  .filter-count {
    font-size: 0.65rem;
    opacity: 0.6;
  }

  /* Work cards */
  .work-card {
    display: flex;
    flex-direction: column;
    overflow: hidden;
    border-radius: 0.75rem;
    border: 1px solid rgba(255,255,255,0.05);
    background: rgba(255,255,255,0.02);
    transition: border-color 0.25s, box-shadow 0.25s, opacity 0.3s, transform 0.3s;
  }
  .work-card:hover {
    border-color: rgba(255,255,255,0.12);
    box-shadow: 0 16px 48px rgba(0,0,0,0.4);
  }
  .work-card.hidden-card {
    opacity: 0;
    pointer-events: none;
    transform: scale(0.97);
  }
  .work-cover {
    position: relative;
    overflow: hidden;
    background: #171717;
  }
  .work-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(10,10,10,0.6) 0%, transparent 60%);
  }
  .work-badge {
    position: absolute;
    top: 0.625rem;
    left: 0.625rem;
    font-size: 0.6rem;
    font-family: monospace;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 9999px;
    padding: 0.2rem 0.5rem;
    color: #a3a3a3;
  }
  .work-info { padding: 1rem 1.25rem 1.25rem; flex: 1; }
</style>

<script>
  const buttons  = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards    = document.querySelectorAll<HTMLElement>('.work-card');
  const empty    = document.getElementById('empty-state')!;

  function applyFilter(filter: string) {
    let visible = 0;
    cards.forEach((card) => {
      const match = filter === 'all' || card.dataset.form === filter;
      card.classList.toggle('hidden-card', !match);
      if (match) visible++;
    });
    empty.classList.toggle('hidden', visible > 0);

    buttons.forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.filter === filter);
    });

    // persist to URL hash so back-button works
    history.replaceState(null, '', filter === 'all' ? '/works' : `/works#${filter}`);
  }

  // Restore from URL hash on load
  const initial = location.hash.slice(1) || 'all';
  applyFilter(initial);

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => applyFilter(btn.dataset.filter ?? 'all'));
  });
</script>
