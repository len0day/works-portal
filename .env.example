# ===== 作品门户 works-portal 环境变量 =====

# 数据库（容器内用 postgres:5432，本地开发用 localhost:5433，复用 AiForKids 的 learningai 库）
DATABASE_URL=postgresql://learningai:password@localhost:5433/learningai

# Portal CMS 独立认证 JWT 密钥（务必与 AiForKids 的 jwt_secret_key 不同！）
PORTAL_JWT_SECRET=change-me-to-a-long-random-string

# Portal rebuild webhook 共享密钥（CMS 发布 → 触发 portal 重新构建）
PORTAL_REBUILD_SECRET=change-me-another-random-string
PORTAL_WEBHOOK_URL=http://localhost:4321/api/rebuild

# 首个管理员账号（仅 db:seed 脚本读取一次）
PORTAL_ADMIN_EMAIL=admin@portal.local
PORTAL_ADMIN_PASSWORD=admin123

# 可选：多平台分发 LLM 增强（默认关闭，留空则纯模板生成）
OPENAI_API_KEY=
