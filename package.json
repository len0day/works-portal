{
  "name": "works-portal",
  "private": true,
  "version": "0.1.0",
  "description": "作品门户 + CMS + 多平台分发系统",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel --filter=./apps/* dev",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @works/db generate",
    "db:migrate": "pnpm --filter @works/db migrate",
    "db:seed": "pnpm --filter @works/db seed",
    "parse": "pnpm --filter @works/parser parse",
    "rebuild-portal": "pnpm --filter @works/portal exec tsx scripts/fetch-cms.ts && pnpm --filter @works/portal build"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
